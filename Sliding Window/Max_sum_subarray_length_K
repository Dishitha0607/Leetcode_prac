class Solution(object):
    def maximumSubarraySum(self, nums, k):
        window_sum=0
        for i in range(k):
            window_sum+=nums[i]
        max_sum = window_sum

        for j in range(len(nums)):
            window_sum+= nums[j]
            window_sum -= nums[j-k]
            max_sum = max(window_sum,max_sum)
        return max_sum
